        {
          "name": "setCpr – GET /cpr-name-gender-dob (prefix + parity)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response has CPR, gender and birthDate', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('CPR');",
                  "  pm.expect(body).to.have.property('gender');",
                  "  pm.expect(body).to.have.property('birthDate');",
                  "});",
                  "",
                  "pm.test('CPR has exactly 10 digits', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.CPR).to.match(/^\\d{10}$/);",
                  "});",
                  "",
                  "pm.test('Gender is male or female', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(['female', 'male']).to.include(body.gender);",
                  "});",
                  "",
                  "pm.test('CPR prefix matches birthDate (DDMMYY)', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.birthDate).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
                  "  const expectedPrefix = body.birthDate.slice(8, 10) + body.birthDate.slice(5, 7) + body.birthDate.slice(2, 4);",
                  "  pm.expect(body.CPR.startsWith(expectedPrefix)).to.equal(true);",
                  "});",
                  "",
                  "pm.test('CPR last digit parity matches gender', function () {",
                  "  const body = pm.response.json();",
                  "  const lastDigit = Number(body.CPR.slice(-1));",
                  "  if (body.gender === 'female') {",
                  "    pm.expect([0, 2, 4, 6, 8]).to.include(lastDigit);",
                  "  } else {",
                  "    pm.expect([1, 3, 5, 7, 9]).to.include(lastDigit);",
                  "  }",
                  "});"
                ]
              }
            }
          ],
