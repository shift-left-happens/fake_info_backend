      "name": "CPR",
      "item": [
        {
          "name": "setCpr – GET /cpr (format)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type is application/json', function () {",
                  "  pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('Response has CPR property', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('CPR');",
                  "});",
                  "",
                  "pm.test('CPR is a string', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.CPR).to.be.a('string');",
                  "});",
                  "",
                  "pm.test('CPR has exactly 10 digits', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.CPR).to.match(/^\\d{10}$/);",
                  "});",
                  "",
                  "pm.test('CPR day part (digits 1-2) is between 01 and 31', function () {",
                  "  const body = pm.response.json();",
                  "  const day = parseInt(body.CPR.slice(0, 2), 10);",
                  "  pm.expect(day).to.be.within(1, 31);",
                  "});",
                  "",
                  "pm.test('CPR month part (digits 3-4) is between 01 and 12', function () {",
                  "  const body = pm.response.json();",
                  "  const month = parseInt(body.CPR.slice(2, 4), 10);",
                  "  pm.expect(month).to.be.within(1, 12);",
                  "});",
                  "",
                  "pm.test('Response time is below 2000ms', function () {",
                  "  pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ]
              }
            }
