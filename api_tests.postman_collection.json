        {
          "name": "GET /name-gender-dob - birthDate format",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const body = pm.response.json();",
                  "",
                  "pm.test('Status is 200', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('birthDate field exists', () => {",
                  "    pm.expect(body).to.have.property('birthDate');",
                  "});",
                  "",
                  "pm.test('birthDate is YYYY-MM-DD format', () => {",
                  "    pm.expect(body.birthDate).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
                  "});",
                  "",
                  "pm.test('year is between 1900 and current year', () => {",
                  "    const year = parseInt(body.birthDate.split('-')[0]);",
                  "    pm.expect(year).to.be.gte(1900);",
                  "    pm.expect(year).to.be.lte(new Date().getFullYear());",
                  "});",
                  "",
                  "pm.test('month is between 1 and 12', () => {",
                  "    const month = parseInt(body.birthDate.split('-')[1]);",
                  "    pm.expect(month).to.be.gte(1);",
                  "    pm.expect(month).to.be.lte(12);",
                  "});",
                  "",
                  "pm.test('day is valid for the given month', () => {",
                  "    const [year, month, day] = body.birthDate.split('-').map(Number);",
                  "    const maxDays = { 2: 28, 4: 30, 6: 30, 9: 30, 11: 30 };",
                  "    const max = maxDays[month] || 31;",
                  "    pm.expect(day).to.be.gte(1);",
                  "    pm.expect(day).to.be.lte(max);",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
